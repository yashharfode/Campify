'use client';

import { useEffect, useMemo, useState } from 'react';
import {
  BadgeIndianRupee,
  BookOpenText,
  Bot,
  Compass,
  Github,
  HandCoins,
  Landmark,
  Linkedin,
  MessageSquareText,
  Network,
  Search,
  ShieldCheck,
  ShoppingBag,
  Sparkles,
  UserRound,
  UsersRound,
  Home,
} from 'lucide-react';
import { onAuthStateChanged } from 'firebase/auth';
import { doc, getDoc } from 'firebase/firestore';
import { auth, db, appId } from '../lib/firebase';
import Marketplace from '../components/Marketplace';
import Discover from '../components/Discover';
import Teams from '../components/Teams';
import Notes from '../components/Notes';
import LostAndFound from '../components/LostAndFound';

const tabs = [
  { id: 'home', label: 'Home', icon: Home },
  { id: 'market', label: 'Market', icon: ShoppingBag },
  { id: 'discover', label: 'Discover', icon: Compass },
  { id: 'network', label: 'Network', icon: Network },
  { id: 'profile', label: 'Profile', icon: UserRound },
];

const marketCategories = ['All', 'Books', 'Electronics', 'Furniture', 'Micro-Gigs', 'Cycles', 'Hostel Deals'];

const marketItems = [
  { title: 'Data Structures Book Set', type: 'Books', price: '650', tag: 'Popular' },
  { title: 'TI Scientific Calculator', type: 'Electronics', price: '900', tag: 'Trusted Seller' },
  { title: 'Micro-Gig: React Debugging Session', type: 'Micro-Gigs', price: '2 hrs barter', tag: 'Skill Barter' },
  { title: 'Micro-Gig: UI Wireframing Sprint', type: 'Micro-Gigs', price: '1 design critique', tag: 'Skill Barter' },
];

const discoverEvents = [
  { title: 'Campus Tech Fest 2026', subtitle: 'Main Auditorium', date: 'Apr 18', type: 'Fest' },
  { title: 'Night Hackathon', subtitle: 'Innovation Hub', date: 'Apr 21', type: 'Hackathon' },
  { title: 'Product Design Meetup', subtitle: 'Design Lab', date: 'Apr 25', type: 'Workshop' },
];

const candidates = [
  { name: 'Aarav Sharma', dept: 'CSE • 3rd Year', skills: ['React', 'TypeScript', 'API Design'] },
  { name: 'Mira Nair', dept: 'IT • 2nd Year', skills: ['UI/UX', 'Figma', 'Prototyping'] },
  { name: 'Kabir Singh', dept: 'ECE • 3rd Year', skills: ['Embedded', 'Python', 'IoT'] },
];

export default function Page() {
  const [activeTab, setActiveTab] = useState('home');
  const [activeCategory, setActiveCategory] = useState('All');
  const [sheetOpen, setSheetOpen] = useState(false);
  const [cardIndex, setCardIndex] = useState(0);
  const [chatOpen, setChatOpen] = useState(false);
  const [chatInput, setChatInput] = useState('');
  const [chatLoading, setChatLoading] = useState(false);
  const [chatMessages, setChatMessages] = useState([
    {
      role: 'assistant',
      content: 'Hi! I am your Uniloop assistant. Ask me about events, notes, gigs, or team building.',
    },
  ]);
  const [profile, setProfile] = useState({
    name: 'Jane Cooper',
    headline: 'Frontend Developer • Campus Builder',
    bio: 'I enjoy building delightful student products and mentoring first-year makers.',
    github: 'github.com/janecooper',
    linkedin: 'linkedin.com/in/janecooper',
  });
  const [user, setUser] = useState(null);
  const [userData, setUserData] = useState(null);
  const [connectedPanel, setConnectedPanel] = useState(null);

  useEffect(() => {
    const unsubscribe = onAuthStateChanged(auth, async (currentUser) => {
      setUser(currentUser || null);
      if (!currentUser) {
        setUserData(null);
        return;
      }
      try {
        const userDoc = await getDoc(doc(db, 'artifacts', appId, 'users', currentUser.uid, 'profile', 'data'));
        setUserData(userDoc.exists() ? userDoc.data() : { name: currentUser.displayName || 'Student', email: currentUser.email || '' });
      } catch {
        setUserData({ name: currentUser.displayName || 'Student', email: currentUser.email || '' });
      }
    });
    return () => unsubscribe();
  });

  const visibleMarket = useMemo(() => {
    if (activeCategory === 'All') return marketItems;
    return marketItems.filter((item) => item.type === activeCategory);
  }, [activeCategory]);

  const candidate = candidates[cardIndex % candidates.length];

  const handleSendChat = async () => {
    const content = chatInput.trim();
    if (!content || chatLoading) return;

    setChatLoading(true);
    setChatInput('');
    const nextMessages = [...chatMessages, { role: 'user', content }];
    setChatMessages(nextMessages);

    try {
      const res = await fetch('/api/chatbot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: content,
          history: nextMessages.slice(-8),
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data?.error || 'Unable to chat right now.');

      setChatMessages((prev) => [
        ...prev,
        { role: 'assistant', content: data.reply || 'I could not generate a response right now.' },
      ]);
    } catch (error) {
      setChatMessages((prev) => [
        ...prev,
        { role: 'assistant', content: error.message || 'Something went wrong while contacting Gemini.' },
      ]);
    } finally {
      setChatLoading(false);
    }
  };

  return (
    <main
      className="min-h-screen pb-28 text-[#1C1917]"
      style={{
        fontFamily: 'Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif',
        background: '#FAF9F6',
      }}
    >
      <div className="mx-auto max-w-6xl px-5 pt-8 md:px-8 md:pt-10">
        <header className="mb-7 flex items-center justify-between">
          <div>
            <p className="text-[11px] uppercase tracking-[0.2em] text-[#71695E]">College Ecosystem</p>
            <h1 className="text-3xl font-semibold tracking-[-0.03em] text-[#2D2A26] md:text-4xl">Uniloop</h1>
          </div>
          <button className="rounded-full bg-[#1C1917] px-5 py-2 text-sm font-medium text-white transition-all duration-300 hover:scale-[1.02]">
            Launch
          </button>
        </header>

        <section key={activeTab} className="animate-[fadeUp_500ms_ease-out]">
          {activeTab === 'home' && <HomeTab onOpenSheet={() => setSheetOpen(true)} onOpenConnected={setConnectedPanel} />}
          {activeTab === 'market' && user && userData && (
            <div className="rounded-3xl border border-[#E8E4D9] bg-white p-2">
              <Marketplace user={user} userData={userData} />
            </div>
          )}
          {activeTab === 'market' && (!user || !userData) && (
            <MarketTab
              categories={marketCategories}
              activeCategory={activeCategory}
              setActiveCategory={setActiveCategory}
              items={visibleMarket}
            />
          )}
          {activeTab === 'discover' && user ? (
            <div className="rounded-3xl border border-[#E8E4D9] bg-white p-2">
              <Discover user={user} />
            </div>
          ) : (
            <DiscoverTab />
          )}
          {activeTab === 'network' && user && userData ? (
            <div className="rounded-3xl border border-[#E8E4D9] bg-white p-2">
              <Teams user={user} userData={userData} />
            </div>
          ) : (
            <NetworkTab
              candidate={candidate}
              onPass={() => setCardIndex((prev) => prev + 1)}
              onConnect={() => setCardIndex((prev) => prev + 1)}
            />
          )}
          {activeTab === 'profile' && <ProfileTab profile={profile} setProfile={setProfile} />}
        </section>
      </div>

      <BottomSheet open={sheetOpen} onClose={() => setSheetOpen(false)} />
      <ConnectedFeaturePanel panel={connectedPanel} onClose={() => setConnectedPanel(null)} user={user} userData={userData} />
      <ChatAssistant
        open={chatOpen}
        setOpen={setChatOpen}
        input={chatInput}
        setInput={setChatInput}
        loading={chatLoading}
        messages={chatMessages}
        onSend={handleSendChat}
      />
      <BottomNav activeTab={activeTab} setActiveTab={setActiveTab} />

      <style jsx>{`
        @keyframes fadeUp {
          from {
            opacity: 0;
            transform: translateY(12px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
      `}</style>
    </main>
  );
}

function HomeTab({ onOpenSheet, onOpenConnected }) {
  const quickActions = [
    { title: 'Sell', icon: HandCoins },
    { title: 'Notes', icon: BookOpenText },
    { title: 'Team', icon: UsersRound },
    { title: 'Lost', icon: Search },
  ];

  return (
    <div className="space-y-6">
      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#7B7368]">Dashboard</p>
        <h2 className="mt-2 text-2xl font-semibold tracking-[-0.02em] text-[#2D2A26]">Good evening, Jane</h2>
        <p className="mt-2 text-sm text-[#60594F]">Everything in one place, now with less campus chaos.</p>
      </section>

      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <div className="mb-5 flex items-center justify-between">
          <h3 className="text-lg font-semibold tracking-[-0.01em] text-[#2D2A26]">Quick Actions</h3>
          <button
            onClick={onOpenSheet}
            className="rounded-full bg-[#1C1917] px-4 py-2 text-xs uppercase tracking-[0.14em] text-white transition-all duration-300 hover:brightness-110"
          >
            Create Team Post
          </button>
        </div>
        <div className="grid grid-cols-2 gap-3 md:grid-cols-4">
          {quickActions.map((action) => (
            <button
              key={action.title}
              className="rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] p-4 text-left transition-all duration-500 hover:-translate-y-0.5"
            >
              <action.icon className="mb-3 h-5 w-5 text-[#2D2A26]" />
              <p className="text-sm font-medium text-[#2D2A26]">{action.title}</p>
            </button>
          ))}
        </div>
      </section>

      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-10 text-center">
        <div className="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[#FAF9F6]">
          <Landmark className="h-6 w-6 text-[#2D2A26]" />
        </div>
        <h3 className="text-lg font-semibold tracking-[-0.01em] text-[#2D2A26]">No Scholarships Yet</h3>
        <p className="mt-2 text-sm text-[#6B645A]">
          Your future is taking a coffee break. We will ping you when fresh scholarships drop.
        </p>
      </section>

      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <h3 className="text-lg font-semibold tracking-[-0.01em] text-[#2D2A26]">Connected Modules</h3>
        <p className="mt-1 text-sm text-[#6B645A]">Your previous Firebase-connected features are available here.</p>
        <div className="mt-4 grid grid-cols-2 gap-3">
          <button onClick={() => onOpenConnected('notes')} className="rounded-2xl bg-[#1C1917] py-3 text-sm font-medium text-white">
            Open Notes
          </button>
          <button onClick={() => onOpenConnected('lost')} className="rounded-2xl border border-[#D9D2C5] py-3 text-sm font-medium text-[#2D2A26]">
            Open Lost & Found
          </button>
        </div>
      </section>
    </div>
  );
}

function ConnectedFeaturePanel({ panel, onClose, user, userData }) {
  if (!panel) return null;

  return (
    <div className="fixed inset-0 z-[60] bg-[#1C1917]/40 backdrop-blur-sm p-4">
      <div className="mx-auto h-full max-w-6xl overflow-auto rounded-3xl border border-[#E8E4D9] bg-[#FAF9F6]">
        <div className="sticky top-0 z-10 flex items-center justify-between border-b border-[#E8E4D9] bg-[#FAF9F6]/95 px-4 py-3 backdrop-blur">
          <h3 className="text-base font-semibold text-[#2D2A26]">{panel === 'notes' ? 'Notes' : 'Lost & Found'}</h3>
          <button onClick={onClose} className="rounded-full border border-[#D9D2C5] px-3 py-1 text-sm text-[#2D2A26]">
            Close
          </button>
        </div>

        {!user ? (
          <div className="p-8 text-center text-[#6B645A]">Login required to load connected features.</div>
        ) : panel === 'notes' ? (
          <Notes user={user} userData={userData} />
        ) : (
          <LostAndFound user={user} userData={userData} />
        )}
      </div>
    </div>
  );
}

function MarketTab({ categories, activeCategory, setActiveCategory, items }) {
  return (
    <div className="space-y-6">
      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#7B7368]">Market + Micro-Gigs</p>
        <h2 className="mt-2 text-2xl font-semibold tracking-[-0.02em]">Buy, sell, barter your skills</h2>
      </section>

      <div className="no-scrollbar flex gap-2 overflow-x-auto pb-1">
        {categories.map((cat) => (
          <button
            key={cat}
            onClick={() => setActiveCategory(cat)}
            className={`whitespace-nowrap rounded-full border px-4 py-2 text-sm transition-all duration-300 ${
              activeCategory === cat ? 'border-[#1C1917] bg-[#1C1917] text-white' : 'border-[#E8E4D9] bg-white text-[#4F473D]'
            }`}
          >
            {cat}
          </button>
        ))}
      </div>

      <div className="grid gap-3">
        {items.map((item) => (
          <article key={item.title} className="rounded-2xl border border-[#E8E4D9] bg-white p-5 transition-all duration-500 hover:-translate-y-0.5">
            <div className="mb-3 flex items-center justify-between">
              <span className="rounded-full bg-[#FAF9F6] px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-[#695F53]">{item.tag}</span>
              <span className="text-sm text-[#6A6155]">{item.type}</span>
            </div>
            <h3 className="text-lg font-semibold tracking-[-0.01em] text-[#2D2A26]">{item.title}</h3>
            <p className="mt-2 flex items-center gap-1 text-sm text-[#1C1917]">
              {item.type !== 'Micro-Gigs' && <BadgeIndianRupee className="h-4 w-4" />}
              {item.price}
            </p>
          </article>
        ))}
      </div>
    </div>
  );
}

function DiscoverTab() {
  return (
    <div className="space-y-4">
      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#7B7368]">Discover Clubs + Events</p>
        <h2 className="mt-2 text-2xl font-semibold tracking-[-0.02em]">Campus energy, curated beautifully</h2>
      </section>

      {discoverEvents.map((event) => (
        <article key={event.title} className="overflow-hidden rounded-3xl border border-[#E8E4D9] bg-white">
          <div className="h-36 w-full bg-gradient-to-r from-[#23201D] to-[#5B544A]" />
          <div className="flex items-start justify-between p-5">
            <div>
              <div className="mb-2 flex items-center gap-2">
                <Sparkles className="h-4 w-4 text-[#1C1917]" />
                <span className="text-[11px] uppercase tracking-[0.18em] text-[#6B645A]">{event.type}</span>
              </div>
              <h3 className="text-lg font-semibold tracking-[-0.01em] text-[#2D2A26]">{event.title}</h3>
              <p className="mt-1 text-sm text-[#6B645A]">{event.subtitle}</p>
            </div>
            <span className="rounded-full border border-[#E8E4D9] px-3 py-1 text-xs text-[#2D2A26]">{event.date}</span>
          </div>
        </article>
      ))}
    </div>
  );
}

function NetworkTab({ candidate, onPass, onConnect }) {
  return (
    <div className="space-y-6">
      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#7B7368]">Team Builder</p>
        <h2 className="mt-2 text-2xl font-semibold tracking-[-0.02em]">LinkedIn meets campus matchmaking</h2>
      </section>

      <article className="rounded-3xl border border-[#E8E4D9] bg-white p-6 transition-all duration-500">
        <div className="mb-6 flex items-center gap-4">
          <div className="h-14 w-14 rounded-full bg-[#FAF9F6] p-3">
            <UserRound className="h-full w-full text-[#2D2A26]" />
          </div>
          <div>
            <h3 className="text-xl font-semibold tracking-[-0.02em] text-[#2D2A26]">{candidate.name}</h3>
            <p className="text-sm text-[#6E665B]">{candidate.dept}</p>
          </div>
        </div>
        <div className="mb-7 flex flex-wrap gap-2">
          {candidate.skills.map((skill) => (
            <span key={skill} className="rounded-full border border-[#E8E4D9] bg-[#FAF9F6] px-3 py-1 text-xs text-[#4F473D]">
              {skill}
            </span>
          ))}
        </div>
        <div className="flex gap-3">
          <button onClick={onPass} className="flex-1 rounded-2xl border border-[#D9D2C5] py-3 text-sm font-medium text-[#2D2A26]">
            Pass
          </button>
          <button onClick={onConnect} className="flex-1 rounded-2xl bg-[#1C1917] py-3 text-sm font-medium text-white">
            Connect
          </button>
        </div>
      </article>
    </div>
  );
}

function ProfileTab({ profile, setProfile }) {
  return (
    <div className="space-y-6">
      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#7B7368]">Profile Resume</p>
        <h2 className="mt-2 text-2xl font-semibold tracking-[-0.02em]">Editable, minimal, professional</h2>
      </section>

      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <div className="grid gap-4 md:grid-cols-2">
          <Input label="Name" value={profile.name} onChange={(value) => setProfile({ ...profile, name: value })} />
          <Input label="Headline" value={profile.headline} onChange={(value) => setProfile({ ...profile, headline: value })} />
        </div>
        <div className="mt-4">
          <label className="mb-2 block text-xs uppercase tracking-[0.18em] text-[#756C60]">Bio</label>
          <textarea
            value={profile.bio}
            onChange={(e) => setProfile({ ...profile, bio: e.target.value })}
            rows={3}
            className="w-full rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] p-3 text-sm outline-none transition focus:border-[#BFB6A8]"
          />
        </div>

        <div className="mt-5 flex gap-3">
          <div className="flex-1 rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] p-3">
            <div className="mb-2 flex items-center gap-2 text-[#2D2A26]">
              <Github className="h-4 w-4" />
              <span className="text-xs uppercase tracking-[0.16em] text-[#756C60]">GitHub</span>
            </div>
            <input
              value={profile.github}
              onChange={(e) => setProfile({ ...profile, github: e.target.value })}
              className="w-full bg-transparent text-sm text-[#2D2A26] outline-none"
            />
          </div>
          <div className="flex-1 rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] p-3">
            <div className="mb-2 flex items-center gap-2 text-[#2D2A26]">
              <Linkedin className="h-4 w-4" />
              <span className="text-xs uppercase tracking-[0.16em] text-[#756C60]">LinkedIn</span>
            </div>
            <input
              value={profile.linkedin}
              onChange={(e) => setProfile({ ...profile, linkedin: e.target.value })}
              className="w-full bg-transparent text-sm text-[#2D2A26] outline-none"
            />
          </div>
        </div>
      </section>

      <section className="grid grid-cols-2 gap-3">
        <StatCard label="Gigs Done" value="18" />
        <StatCard label="Notes Shared" value="42" />
      </section>

      <section className="rounded-3xl border border-[#E8E4D9] bg-white p-6 md:p-8">
        <h3 className="text-lg font-semibold tracking-[-0.01em] text-[#2D2A26]">Projects Showcase</h3>
        <div className="mt-4 grid gap-3">
          {['Hostel Maintenance App', 'Smart Notes Finder', 'Campus Lost & Found Bot'].map((project) => (
            <div key={project} className="rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] p-4 text-sm text-[#3A342D]">
              {project}
            </div>
          ))}
        </div>
      </section>
    </div>
  );
}

function BottomNav({ activeTab, setActiveTab }) {
  return (
    <nav className="fixed inset-x-0 bottom-4 z-40 mx-auto flex max-w-md justify-center px-4">
      <div className="relative flex w-full items-center justify-between rounded-full border border-[#DDD7C8] bg-white/70 px-2 py-2 backdrop-blur-xl">
        {tabs.map((tab) => {
          const Icon = tab.icon;
          const isActive = tab.id === activeTab;
          return (
            <button
              key={tab.id}
              onClick={() => setActiveTab(tab.id)}
              className="relative z-10 flex w-14 flex-col items-center justify-center py-1"
            >
              <span className={`absolute h-9 w-9 rounded-full transition-all duration-500 ${isActive ? 'scale-100 bg-[#1C1917]' : 'scale-0'}`} />
              <Icon className={`relative h-4 w-4 ${isActive ? 'text-white' : 'text-[#5B5348]'}`} />
              <span className={`relative mt-1 text-[10px] ${isActive ? 'text-[#1C1917]' : 'text-[#7A7266]'}`}>{tab.label}</span>
            </button>
          );
        })}
      </div>
    </nav>
  );
}

function BottomSheet({ open, onClose }) {
  return (
    <div className={`fixed inset-0 z-50 transition-all duration-500 ${open ? 'pointer-events-auto' : 'pointer-events-none'}`}>
      <button onClick={onClose} className={`absolute inset-0 bg-[#1C1917]/30 transition-opacity duration-500 ${open ? 'opacity-100' : 'opacity-0'}`} />
      <div
        className={`absolute inset-x-0 bottom-0 rounded-t-3xl border border-[#E8E4D9] bg-[#FAF9F6] p-6 transition-transform duration-500 ${
          open ? 'translate-y-0' : 'translate-y-full'
        }`}
      >
        <div className="mx-auto mb-4 h-1.5 w-12 rounded-full bg-[#D6CFBF]" />
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#7B7368]">Create Team Post</p>
        <h3 className="mt-2 text-xl font-semibold tracking-[-0.02em] text-[#2D2A26]">Find your build crew</h3>
        <div className="mt-4 space-y-3">
          <input placeholder="Project title" className="w-full rounded-2xl border border-[#E8E4D9] bg-white p-3 text-sm outline-none" />
          <textarea placeholder="Skills needed" rows={3} className="w-full rounded-2xl border border-[#E8E4D9] bg-white p-3 text-sm outline-none" />
          <button onClick={onClose} className="w-full rounded-2xl bg-[#1C1917] py-3 text-sm font-medium text-white">
            Publish
          </button>
        </div>
      </div>
    </div>
  );
}

function ChatAssistant({ open, setOpen, input, setInput, loading, messages, onSend }) {
  return (
    <>
      <button
        onClick={() => setOpen((prev) => !prev)}
        className="fixed bottom-24 right-5 z-40 rounded-full border border-[#E8E4D9] bg-white p-3 text-[#1C1917] shadow-sm transition-all duration-300 hover:scale-[1.03]"
        aria-label="Toggle assistant"
      >
        <Bot className="h-5 w-5" />
      </button>

      <div
        className={`fixed bottom-40 right-5 z-40 w-[22rem] max-w-[calc(100vw-2.5rem)] rounded-3xl border border-[#E8E4D9] bg-white transition-all duration-500 ${
          open ? 'pointer-events-auto translate-y-0 opacity-100' : 'pointer-events-none translate-y-4 opacity-0'
        }`}
      >
        <div className="flex items-center justify-between border-b border-[#E8E4D9] px-4 py-3">
          <div className="flex items-center gap-2">
            <MessageSquareText className="h-4 w-4 text-[#1C1917]" />
            <p className="text-sm font-semibold text-[#2D2A26]">Campus Assistant</p>
          </div>
          <ShieldCheck className="h-4 w-4 text-[#7B7368]" />
        </div>

        <div className="h-64 space-y-3 overflow-y-auto px-4 py-3">
          {messages.map((msg, index) => (
            <div
              key={`${msg.role}-${index}`}
              className={`max-w-[88%] rounded-2xl px-3 py-2 text-sm ${msg.role === 'user' ? 'ml-auto bg-[#1C1917] text-white' : 'bg-[#FAF9F6] text-[#2D2A26]'}`}
            >
              {msg.content}
            </div>
          ))}
        </div>

        <div className="flex gap-2 border-t border-[#E8E4D9] p-3">
          <input
            value={input}
            onChange={(e) => setInput(e.target.value)}
            onKeyDown={(e) => {
              if (e.key === 'Enter') onSend();
            }}
            placeholder="Ask about campus resources..."
            className="flex-1 rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] px-3 py-2 text-sm outline-none"
          />
          <button onClick={onSend} disabled={loading} className="rounded-2xl bg-[#1C1917] px-4 text-sm font-medium text-white disabled:opacity-60">
            {loading ? '...' : 'Send'}
          </button>
        </div>
      </div>
    </>
  );
}

function Input({ label, value, onChange }) {
  return (
    <div>
      <label className="mb-2 block text-xs uppercase tracking-[0.18em] text-[#756C60]">{label}</label>
      <input
        value={value}
        onChange={(e) => onChange(e.target.value)}
        className="w-full rounded-2xl border border-[#E8E4D9] bg-[#FAF9F6] p-3 text-sm outline-none transition focus:border-[#BFB6A8]"
      />
    </div>
  );
}

function StatCard({ label, value }) {
  return (
    <div className="rounded-3xl border border-[#E8E4D9] bg-white p-5">
      <p className="text-[11px] uppercase tracking-[0.16em] text-[#7B7368]">{label}</p>
      <p className="mt-1 text-2xl font-semibold tracking-[-0.02em] text-[#2D2A26]">{value}</p>
    </div>
  );
}
